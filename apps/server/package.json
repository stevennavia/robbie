    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@robbie/shared": "*",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.0",
    "supertest": "^7.1.0",
    "tsx": "^4.19.2"
  }
}
