{
  "name": "@robbie/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Servidor local de Robbie Virtual (Express + WebSocket)",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
