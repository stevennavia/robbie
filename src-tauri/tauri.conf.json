{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Robbie",
  "version": "0.1.0",
  "identifier": "com.robbie.virtual",
  "build": {
    "beforeDevCommand": "npm run dev:client",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../apps/client/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "dashboard",
        "title": "Robbie Dashboard",
        "url": "index.html?window=dashboard",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "center": true
      },
      {
        "label": "robbie",
        "title": "Robbie",
        "url": "index.html?window=robbie",
        "width": 128,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "focus": false,
        "shadow": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "resources": [
      "../apps/server/dist",
      "../packages/shared/dist",
      "../node_modules/@robbie/shared"
    ]
  }
}
